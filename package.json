{
  "name": "opensupport-agentops",
  "version": "0.1.0",
  "private": true,
  "description": "Tenant-ready ecommerce customer support AgentOps platform based on Chatwoot.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "trellis:context": "python3 ./.trellis/scripts/get_context.py",
    "trellis:tasks": "python3 ./.trellis/scripts/task.py list --mine",
    "build": "tsc -b --pretty false",
    "db:up": "docker compose -f infra/docker/compose.phase1.yml up -d",
    "db:psql": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\"",
    "db:migrate": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/migrations/0001_phase1_foundation.sql -f infra/migrations/0002_tenant_model_config_versions.sql -f infra/migrations/0003_llm_call_logging_cost_governance.sql -f infra/migrations/0004_pii_mask_trace_schema.sql -f infra/migrations/0005_policy_corpus_hybrid_retrieval.sql -f infra/migrations/0006_ticket_execution_state_machine.sql -f infra/migrations/0007_runtime_mode_decisions.sql -f infra/migrations/0008_approval_snapshots.sql -f infra/migrations/0009_approval_actions.sql -f infra/migrations/0010_eval_foundation.sql -f infra/migrations/0011_release_candidates.sql -f infra/migrations/0012_release_gate_results.sql -f infra/migrations/0013_failure_cases.sql",
    "db:verify": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -P pager=off -c \"select table_name from information_schema.tables where table_schema='public' and table_type='BASE TABLE' order by table_name;\"",
    "db:verify:model-config": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase1c_tenant_model_config.sql",
    "db:verify:llm-observability": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase1d_llm_observability.sql",
    "db:verify:trace": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase1e_trace_schema.sql",
    "db:verify:retrieval": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase2c_policy_retrieval.sql",
    "db:verify:runtime-control": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase3a_ticket_execution_state_machine.sql",
    "db:verify:runtime-mode": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase3b_runtime_mode_decisions.sql",
    "db:verify:approvals": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase3d_approval_snapshots.sql",
    "db:verify:approval-actions": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase3e_approval_actions.sql",
    "db:verify:eval": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase4a_eval_foundation.sql",
    "db:verify:release-candidate": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase4d_release_candidates.sql",
    "db:verify:release-gate": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase4e_release_gate.sql",
    "db:verify:failure-cases": "psql \"${DATABASE_URL:-postgresql://agentops:agentops@localhost:5432/agentops}\" -v ON_ERROR_STOP=1 -f infra/verification/phase4f_failure_cases.sql",
    "lint": "git diff --check",
    "test": "npm run test:phase1 && npm run test:phase1a && npm run test:phase1c && npm run test:phase1d && npm run test:phase1e && npm run test:chatwoot && npm run test:model-config && npm run test:llm-observability && npm run test:pii && npm run test:trace && npm run test:phase2a && npm run test:agent-core && npm run test:phase2b && npm run test:llm-runtime && npm run test:phase2c && npm run test:retrieval && npm run test:phase2d && npm run test:rag && npm run test:phase2e && npm run test:tools && npm run test:phase2f && npm run test:guardrails && npm run test:phase2g && npm run test:agent-runtime && npm run test:phase2 && npm run test:phase3a && npm run test:phase3b && npm run test:runtime-control && npm run test:phase3c && npm run test:phase3d && npm run test:phase3e && npm run test:approvals && npm run test:phase3f && npm run test:runtime-orchestrator && npm run test:phase3 && npm run test:phase4a && npm run test:phase4b && npm run test:phase4c && npm run test:phase4d && npm run test:phase4e && npm run test:phase4f && npm run test:eval && npm run reports:phase4:check && npm run test:phase4 && npm run test:phase5a && npm run test:phase5b && npm run test:phase5c && npm run test:phase5d && npm run test:phase5e && npm run test:phase5f && npm run test:phase5",
    "test:chatwoot": "npm run build && node --test packages/chatwoot/dist/*.test.js",
    "test:model-config": "npm run build && node --test packages/model-config/dist/*.test.js",
    "test:llm-observability": "npm run build && node --test packages/llm-observability/dist/*.test.js",
    "test:pii": "npm run build && node --test packages/pii/dist/*.test.js",
    "test:trace": "npm run build && node --test packages/trace/dist/*.test.js",
    "test:agent-core": "npm run build && node --test packages/agent-core/dist/*.test.js",
    "test:llm-runtime": "npm run build && node --test packages/llm-runtime/dist/*.test.js",
    "test:retrieval": "npm run build && node --test packages/retrieval/dist/*.test.js",
    "test:rag": "npm run build && node --test packages/rag/dist/*.test.js",
    "test:tools": "npm run build && node --test packages/tools/dist/*.test.js",
    "test:guardrails": "npm run build && node --test packages/guardrails/dist/*.test.js",
    "test:agent-runtime": "npm run build && node --test packages/agent-runtime/dist/*.test.js",
    "test:runtime-control": "npm run build && node --test packages/runtime-control/dist/*.test.js",
    "test:approvals": "npm run build && node --test packages/approvals/dist/*.test.js",
    "test:runtime-orchestrator": "npm run build && node --test packages/runtime-orchestrator/dist/*.test.js",
    "test:eval": "npm run build && node --test packages/eval/dist/*.test.js",
    "reports:phase4": "npm run build && node scripts/generate-phase4-reports.mjs",
    "reports:phase4:check": "npm run build && node scripts/generate-phase4-reports.mjs --check",
    "reports:phase5:benchmark": "npm run build && node scripts/generate-phase5-benchmark-report.mjs",
    "reports:phase5:benchmark:check": "npm run build && node scripts/generate-phase5-benchmark-report.mjs --check",
    "reports:phase5": "npm run build && node scripts/generate-phase5-benchmark-report.mjs && node scripts/generate-phase5-reports.mjs",
    "reports:phase5:check": "npm run build && node scripts/generate-phase5-benchmark-report.mjs --check && node scripts/generate-phase5-reports.mjs --check",
    "test:phase1": "node scripts/validate-phase1.mjs",
    "test:phase1a": "node scripts/validate-phase1a.mjs",
    "test:phase1c": "node scripts/validate-phase1c.mjs",
    "test:phase1d": "node scripts/validate-phase1d.mjs",
    "test:phase1e": "node scripts/validate-phase1e.mjs",
    "test:phase2a": "node scripts/validate-phase2a.mjs",
    "test:phase2b": "node scripts/validate-phase2b.mjs",
    "test:phase2c": "node scripts/validate-phase2c.mjs",
    "test:phase2d": "node scripts/validate-phase2d.mjs",
    "test:phase2e": "node scripts/validate-phase2e.mjs",
    "test:phase2f": "node scripts/validate-phase2f.mjs",
    "test:phase2g": "node scripts/validate-phase2g.mjs",
    "test:phase2": "node scripts/validate-phase2.mjs",
    "test:phase3a": "node scripts/validate-phase3a.mjs",
    "test:phase3b": "node scripts/validate-phase3b.mjs",
    "test:phase3c": "node scripts/validate-phase3c.mjs",
    "test:phase3d": "node scripts/validate-phase3d.mjs",
    "test:phase3e": "node scripts/validate-phase3e.mjs",
    "test:phase3f": "node scripts/validate-phase3f.mjs",
    "test:phase3": "node scripts/validate-phase3.mjs",
    "test:phase4a": "node scripts/validate-phase4a.mjs",
    "test:phase4b": "node scripts/validate-phase4b.mjs",
    "test:phase4c": "node scripts/validate-phase4c.mjs",
    "test:phase4d": "node scripts/validate-phase4d.mjs",
    "test:phase4e": "node scripts/validate-phase4e.mjs",
    "test:phase4f": "node scripts/validate-phase4f.mjs",
    "test:phase4": "node scripts/validate-phase4.mjs",
    "test:phase5a": "npm run build && node --test packages/eval/dist/benchmark.test.js && node scripts/validate-phase5a.mjs",
    "test:phase5b": "npm run build && node --test packages/eval/dist/reference-adapters.test.js && node scripts/validate-phase5b.mjs",
    "test:phase5c": "npm run build && node --test packages/eval/dist/selective-adapters.test.js && node scripts/validate-phase5c.mjs",
    "test:phase5d": "npm run build && node --test packages/eval/dist/comparison.test.js && node scripts/validate-phase5d.mjs && node scripts/generate-phase5-benchmark-report.mjs --check",
    "test:phase5e": "npm run build && node --test packages/eval/dist/load.test.js && node scripts/validate-phase5e.mjs",
    "test:phase5f": "npm run build && node scripts/validate-phase5f.mjs && npm run reports:phase5:check",
    "test:phase5": "node scripts/validate-phase5.mjs",
    "typecheck": "tsc -b --pretty false"
  },
  "keywords": [],
  "author": "Grove-ovo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
