NODE_ENV=development
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
AGENTOPS_BUILD_VERSION=dev
AGENTOPS_REQUIRED_MIGRATION=15
AGENTOPS_DEDUPE_TTL_SECONDS=86400
AGENTOPS_SHUTDOWN_TIMEOUT_MS=10000
AGENTOPS_PIPELINE_DEADLINE_MS=30000
AGENTOPS_APPROVAL_TTL_MS=86400000

# Provider HTTP endpoints and token pricing. OpenAI and Anthropic have official
# defaults; compatible providers require an explicit base URL.
AGENTOPS_PROVIDER_BASE_URLS_JSON={"openai":"https://api.openai.com","anthropic":"https://api.anthropic.com"}
AGENTOPS_MODEL_PRICING_JSON={"gpt-4.1-mini":{"inputCostPerMillion":0.4,"outputCostPerMillion":1.6}}

# Storage
DATABASE_URL=postgresql://agentops:agentops@localhost:5432/agentops
REDIS_URL=redis://localhost:6379/0
AGENTOPS_POSTGRES_USER=agentops
AGENTOPS_POSTGRES_PASSWORD=agentops
AGENTOPS_POSTGRES_DB=agentops
AGENTOPS_POSTGRES_PORT=5432
AGENTOPS_REDIS_PORT=6379

# Chatwoot
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_ACCOUNT_ID=1
# Store these names as env:CHATWOOT_WEBHOOK_SECRET and
# env:CHATWOOT_API_TOKEN in chatwoot_connections.
CHATWOOT_WEBHOOK_SECRET=change-me
CHATWOOT_API_TOKEN=change-me

# BYOK local envelope encryption key. Must decode to exactly 32 bytes.
AGENTOPS_MASTER_KEY=base64url:<base64url-encoded-32-byte-key>
AGENTOPS_MASTER_KEY_ID=local-v1

# Operator OIDC. The identity provider must return `sub`, roles, and tenant
# scope claims. Session key files contain exactly 32 random bytes, newest first.
AGENTOPS_OIDC_ISSUER=https://identity.example.com/realms/agentops
AGENTOPS_OIDC_CLIENT_ID=opensupport-agentops
AGENTOPS_OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
AGENTOPS_OIDC_CALLBACK_URI=http://localhost:5173/api/v1/auth/callback
AGENTOPS_OIDC_ROLE_CLAIM=agentops_roles
AGENTOPS_OIDC_TENANT_CLAIM=agentops_tenants
AGENTOPS_OIDC_OPERATOR_ROLE=operator
AGENTOPS_OIDC_ADMIN_ROLE=admin
AGENTOPS_OPERATOR_SESSION_KEY_FILES=./secrets/agentops_operator_session_key
AGENTOPS_OPERATOR_SESSION_TTL_SECONDS=3600
AGENTOPS_COOKIE_SECURE=false
AGENTOPS_HTTP_BODY_LIMIT_BYTES=1048576
AGENTOPS_HTTP_REQUEST_TIMEOUT_MS=35000
AGENTOPS_HTTP_CONNECTION_TIMEOUT_MS=10000
AGENTOPS_HTTP_KEEPALIVE_TIMEOUT_MS=20000
AGENTOPS_HTTP_MAX_REQUESTS_PER_SOCKET=1000

# Async worker runtime.
AGENTOPS_STREAM_KEY=agentops:jobs
AGENTOPS_STREAM_GROUP=agentops-workers
AGENTOPS_DEAD_LETTER_STREAM=agentops:jobs:dead
AGENTOPS_WORKER_CONSUMER=worker-local-1
AGENTOPS_WORKER_PORT=8081
AGENTOPS_WORKER_MAX_ATTEMPTS=3
AGENTOPS_WORKER_VISIBILITY_TIMEOUT_MS=30000
AGENTOPS_WORKER_RELAY_INTERVAL_MS=500
AGENTOPS_WORKER_READ_BLOCK_MS=1000
AGENTOPS_WORKER_BATCH_SIZE=25

# Opt-in live smoke inputs. The smoke command sends a real signed event.
AGENTOPS_API_URL=http://localhost:8080
AGENTOPS_SMOKE_TENANT_ID=<tenant-uuid>
AGENTOPS_SMOKE_CONVERSATION_ID=1
AGENTOPS_SMOKE_CONTACT_ID=1
AGENTOPS_SMOKE_MESSAGE=What is the status of order ORD-100?
