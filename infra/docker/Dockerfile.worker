FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json tsconfig.json tsconfig.base.json ./
COPY apps ./apps
COPY packages ./packages
RUN npm ci && npm run build -- --force && npm prune --omit=dev

FROM node:22-alpine AS runtime
ENV NODE_ENV=production
WORKDIR /app
RUN addgroup -S agentops && adduser -S -G agentops agentops
COPY --from=build --chown=agentops:agentops /app/package.json /app/package-lock.json ./
COPY --from=build --chown=agentops:agentops /app/node_modules ./node_modules
COPY --from=build --chown=agentops:agentops /app/apps/worker ./apps/worker
COPY --from=build --chown=agentops:agentops /app/packages ./packages
USER agentops
EXPOSE 8081
CMD ["node", "apps/worker/dist/server.js"]
