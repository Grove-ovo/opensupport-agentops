AGENTOPS_BUILD_VERSION=local
AGENTOPS_PUBLIC_PORT=8088
AGENTOPS_PUBLIC_URL=https://agentops.example.com
AGENTOPS_POSTGRES_USER=agentops
AGENTOPS_POSTGRES_PASSWORD=replace-with-long-random-password
AGENTOPS_POSTGRES_DB=agentops
AGENTOPS_POSTGRES_PORT=55432
AGENTOPS_REDIS_PASSWORD=replace-with-long-random-password
AGENTOPS_REDIS_PORT=56379
AGENTOPS_PROMETHEUS_PORT=9090
AGENTOPS_GRAFANA_PORT=3001
AGENTOPS_MASTER_KEY_FILE=../../secrets/agentops_master_key
AGENTOPS_OIDC_ISSUER=https://identity.example.com/realms/agentops
AGENTOPS_OIDC_CLIENT_ID=opensupport-agentops
AGENTOPS_OIDC_CLIENT_SECRET_FILE=../../secrets/agentops_oidc_client_secret
AGENTOPS_OIDC_CALLBACK_URI=https://agentops.example.com/api/v1/auth/callback
AGENTOPS_OIDC_ROLE_CLAIM=agentops_roles
AGENTOPS_OIDC_TENANT_CLAIM=agentops_tenants
AGENTOPS_OIDC_OPERATOR_ROLE=operator
AGENTOPS_OIDC_ADMIN_ROLE=admin
AGENTOPS_OPERATOR_SESSION_KEY_FILE=../../secrets/agentops_operator_session_key
AGENTOPS_OPERATOR_SESSION_TTL_SECONDS=3600
AGENTOPS_COOKIE_SECURE=true
AGENTOPS_HTTP_BODY_LIMIT_BYTES=1048576
AGENTOPS_HTTP_REQUEST_TIMEOUT_MS=35000
AGENTOPS_HTTP_CONNECTION_TIMEOUT_MS=10000
AGENTOPS_HTTP_KEEPALIVE_TIMEOUT_MS=20000
AGENTOPS_HTTP_MAX_REQUESTS_PER_SOCKET=1000
AGENTOPS_PUBLIC_SCHEME=https
AGENTOPS_HSTS_VALUE=max-age=31536000; includeSubDomains
AGENTOPS_BACKUP_DIR=/var/backups/opensupport-agentops
AGENTOPS_BACKUP_RETENTION_DAYS=30
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD_FILE=../../secrets/grafana_admin_password
AGENTOPS_PROVIDER_BASE_URLS_JSON={}
AGENTOPS_MODEL_PRICING_JSON={}
CHATWOOT_WEBHOOK_SECRET=
CHATWOOT_API_TOKEN=
SMOKE_CHATWOOT_WEBHOOK_SECRET=smoke-webhook-secret
SMOKE_CHATWOOT_API_TOKEN=smoke-chatwoot-token
