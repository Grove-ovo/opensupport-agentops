{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@opensupport/shared": ["packages/shared/src/index.ts"],
      "@opensupport/chatwoot": ["packages/chatwoot/src/index.ts"],
      "@opensupport/model-config": ["packages/model-config/src/index.ts"],
      "@opensupport/llm-observability": ["packages/llm-observability/src/index.ts"],
      "@opensupport/pii": ["packages/pii/src/index.ts"],
      "@opensupport/trace": ["packages/trace/src/index.ts"],
      "@opensupport/agent-core": ["packages/agent-core/src/index.ts"],
      "@opensupport/llm-runtime": ["packages/llm-runtime/src/index.ts"],
      "@opensupport/retrieval": ["packages/retrieval/src/index.ts"],
      "@opensupport/rag": ["packages/rag/src/index.ts"],
      "@opensupport/tools": ["packages/tools/src/index.ts"]
    }
  }
}
